<div style="flex:1;background:#161d2e;border-radius:4px;height:18px;position:relative;overflow:hidden">
<div style="width:{pct:.0f}%;height:18px;background:{cols[label]};border-radius:4px"></div>
<span style="position:absolute;left:6px;top:50%;transform:translateY(-50%);font-size:0.65rem;color:#fff;font-weight:700">{count}</span>
</div>
</div>”””
