def donut_svg(slices, cx=75, cy=75, r=55, hole=30):
“”“Pure-SVG donut. slices = list of (label, count, color)”””
total_v = sum(s[1] for s in slices) or 1
cumAngle = -90
paths = []
for label, val, color in slices:
angle = (val / total_v) * 360
if angle == 0: continue
startRad = cumAngle * 3.14159/180
endRad   = (cumAngle+angle) * 3.14159/180
x1 = cx + r***import**(‘math’).cos(startRad)
y1 = cy + r***import**(‘math’).sin(startRad)
x2 = cx + r***import**(‘math’).cos(endRad)
y2 = cy + r***import**(‘math’).sin(endRad)
large = 1 if angle > 180 else 0
xi1 = cx + hole***import**(‘math’).cos(startRad)
yi1 = cy + hole***import**(‘math’).sin(startRad)
xi2 = cx + hole***import**(‘math’).cos(endRad)
yi2 = cy + hole***import**(‘math’).sin(endRad)
d = f”M{xi1:.1f},{yi1:.1f} L{x1:.1f},{y1:.1f} A{r},{r} 0 {large} 1 {x2:.1f},{y2:.1f} L{xi2:.1f},{yi2:.1f} A{hole},{hole} 0 {large} 0 {xi1:.1f},{yi1:.1f} Z”
paths.append(f’<path d="{d}" fill="{color}" opacity="0.9"/>’)
cumAngle += angle
legend = “”.join(
f’<div style="display:flex;align-items:center;gap:6px;font-size:0.7rem;color:#4a5568">’
f’<div style="width:8px;height:8px;border-radius:50%;background:{c};flex-shrink:0"></div>’
f’<span style="color:#eef2ff">{l}</span><span style="color:#3d4a65;margin-left:auto">{v}</span></div>’
for l,v,c in slices if v > 0
)
svg = f’<svg width="150" height="150" viewBox="0 0 150 150">{””.join(paths)}<circle cx="{cx}" cy="{cy}" r="{hole}" fill="#0d1220"/><text x="{cx}" y="{cy-4}" text-anchor="middle" fill="#eef2ff" font-size="14" font-weight="800" font-family="Syne,sans-serif">{total_v}</text><text x="{cx}" y="{cy+12}" text-anchor="middle" fill="#3d4a65" font-size="8">total</text></svg>’
return f’<div style="display:flex;flex-direction:column;align-items:center;gap:10px">{svg}<div style="display:flex;flex-direction:column;gap:4px;width:140px">{legend}</div></div>’

def hbar_chart(data, title=””):
“”“data = list of (label, val, color)”””
