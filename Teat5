EXPORT_COLUMNS = [
“No”,“Name”,“Mobile”,“Email”,“Major”,“Degree”,
“Years of Experience”,“Current / Last Position”,“Current Employer”,
“Category”,“Suitable Department”,“Priority”,“Status”,“Note”,
“AI Score (%)”,“Relevance Score (%)”,“Semantic Score (%)”,“Potential Score (%)”,
