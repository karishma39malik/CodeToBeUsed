        row_bg    = colors.HexColor("#FFF4E5")
        fit_color = AMBER
    else:
        row_bg    = colors.HexColor("#FFECEC")
        fit_color = RED

    sc_color = GREEN if comp >= 0.65 else (AMBER if comp >= 0.45 else RED)

    # Build hex strings safely
    sc_hex  = sc_color.hexval()[2:]
    fit_hex = fit_color.hexval()[2:]

    row_data = [
        Paragraph(f"<b>#{rank}</b>", normal_style),
        Paragraph(
            f"<b>{name}</b><br/>"
            f"<font size=6 color='grey'>{email}</font><br/>"
            f"<font size=5 color='#BCC0C4'>{phone}</font>",
            normal_style,
        ),
        Paragraph(loc,     small_style),
        Paragraph(gender,  small_style),
        Paragraph(
            f"<b>{exp_yrs}</b>" + ("<font size=5 color='grey'> yrs</font>" if exp_yrs != "—" else ""),
            small_style,
        ),
        Paragraph(f"<b>{degree}</b><br/><font size=5 color='grey'>{major}</font>", small_style),
        Paragraph(f"<b>{desig}</b><br/><font size=5 color='grey'>{employer}</font>", small_style),
        Paragraph(dept, small_style),
        Paragraph(
            f"<b><font color='#{sc_hex}'>{score_pct}%</font></b><br/>"
            f"<font size=5 color='grey'>R:{int(rel*100)} S:{int(sem*100)} P:{int(pot*100)}</font>",
            small_style,
        ),
        Paragraph(
            f"<b><font color='#{fit_hex}'>{fit_text}</font></b><br/>"
            f"<font size=5 color='grey'>{priority}</font>",
            small_style,
        ),
        Paragraph(rationale[:220] + ("…" if len(rationale) > 220 else ""), small_style),
    ]
    table_data.append(row_data)
    row_bgs.append((len(table_data) - 1, row_bg))

cand_table = Table(table_data, colWidths=COL_WIDTHS, repeatRows=1)

style_cmds = [
    ("BACKGROUND",    (0, 0), (-1, 0),  LGRAY),
    ("LINEBELOW",     (0, 0), (-1, 0),  0.8,  BLUE),
    ("INNERGRID",     (0, 0), (-1, -1), 0.3,  MGRAY),
    ("BOX",           (0, 0), (-1, -1), 0.5,  MGRAY),
    ("VALIGN",        (0, 0), (-1, -1), "TOP"),
    ("TOPPADDING",    (0, 0), (-1, -1), 4),
    ("BOTTOMPADDING", (0, 0), (-1, -1), 4),
    ("LEFTPADDING",   (0, 0), (-1, -1), 3),
    ("RIGHTPADDING",  (0, 0), (-1, -1), 3),
]
for row_idx, bg in row_bgs:
    style_cmds.append(("BACKGROUND", (0, row_idx), (-1, row_idx), bg))

cand_table.setStyle(TableStyle(style_cmds))
elements.append(cand_table)

elements.append(Spacer(1, 8))
elements.append(HRFlowable(width="100%", thickness=0.5, color=MGRAY))
elements.append(Spacer(1, 4))
elements.append(Paragraph(
    f"Generated by TalentScan AI  |  {datetime.now().strftime('%d %b %Y, %H:%M')}  |  Confidential",
    footer_style,
))

doc.build(elements)
buffer.seek(0)
